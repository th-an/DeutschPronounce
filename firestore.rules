rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sujithkannan5589@gmail.com" && request.auth.token.email_verified == true));
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'currentLevel']) &&
             data.uid == request.auth.uid &&
             data.currentLevel in ['Letters', 'Numbers', 'Words', 'A1', 'A2', 'B1', 'B2', 'C1', 'C2'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }
    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'phrase', 'score', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.score >= 0 && data.score <= 100 &&
             data.phrase is string && data.phrase.size() < 500 &&
             (!('feedback' in data) || (data.feedback is string && data.feedback.size() < 2000)) &&
             (!('transcription' in data) || (data.transcription is string && data.transcription.size() < 2000));
    }

    function isValidAudioCache(data) {
      return data.keys().hasAll(['phrase', 'voice', 'audioData', 'mimeType']) &&
             data.phrase is string && data.phrase.size() < 500 &&
             data.voice is string && data.voice.size() < 50 &&
             data.audioData is string && data.audioData.size() < 1000000 &&
             data.mimeType is string && data.mimeType.size() < 100;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /scores/{scoreId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /audio_cache/{phraseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAudioCache(request.resource.data);
    }
  }
}
